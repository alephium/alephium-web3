{
  "name": "@alephium/web3-wallet",
  "version": "2.1.0-test.0",
  "description": "Simple wallets for Alephium",
  "keywords": [
    "alephium",
    "web3"
  ],
  "license": "GPL",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alephium/alephium-web3.git"
  },
  "homepage": "https://github.com/alephium/alephium-web3",
  "bugs": {
    "url": "https://github.com/alephium/alephium-web3/issues"
  },
  "author": "Alephium dev <dev@alephium.org>",
  "scripts": {
    "clean": "rm -rf node_modules dist",
    "build": "tsup && tsc --emitDeclarationOnly --declaration --outDir dist/types",
    "test": "jest -i --config ./jest-config.json"
  },
  "dependencies": {
    "@alephium/web3": "workspace:^",
    "@noble/secp256k1": "1.7.1",
    "@scure/bip32": "^1.2.0",
    "@scure/bip39": "^1.5.0"
  },
  "devDependencies": {
    "@types/jest": "^27.5.2",
    "@types/mock-fs": "^4.13.1",
    "@types/rewire": "^2.5.28",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "tsup": "^8.5.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=7.0.0"
  }
}

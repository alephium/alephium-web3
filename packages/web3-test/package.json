{
  "name": "@alephium/web3-test",
  "version": "3.0.0-test.9",
  "description": "Utility functions for Alephium test",
  "keywords": [
    "alephium",
    "web3"
  ],
  "license": "GPL",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alephium/alephium-web3.git"
  },
  "homepage": "https://github.com/alephium/alephium-web3",
  "bugs": {
    "url": "https://github.com/alephium/alephium-web3/issues"
  },
  "author": "Alephium dev <dev@alephium.org>",
  "scripts": {
    "build": "pnpm clean && tsc --build .",
    "clean": "rm -rf dist",
    "clean:all": "pnpm clean && rm -rf node_modules",

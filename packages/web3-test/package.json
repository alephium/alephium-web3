  },
  "type": "commonjs",
  "dependencies": {
    "@alephium/web3": "workspace:^",
    "@alephium/web3-wallet": "workspace:^"
  },
  "devDependencies": {
    "@types/jest": "^27.5.2",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=7.0.0"
  }
}

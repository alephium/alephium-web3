{
  "compilerOptions": {
    "target": "es2020",
    "allowJs": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "module": "es2020",
    "declaration": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noImplicitOverride": true
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  }
}
